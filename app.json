{
  "expo": {
    "name": "Masareef",
    "slug": "tmp-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "masareef",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/71a16c6f-6abc-4172-b12a-9958a6d05f44"
    },
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Allow $(PRODUCT_NAME) to use speech recognition to transcribe spoken expenses.",
        "NSMicrophoneUsageDescription": "Allow $(PRODUCT_NAME) to use the microphone to capture spoken expenses.",
        "NSPhotoLibraryUsageDescription": "Masareef accesses your photo library only if you choose to attach an image to a transaction; it never reads your photos otherwise.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.abdallah.masareef",
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.com.abdallah.masareef"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0B0F0E",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 240,
          "resizeMode": "contain",
          "backgroundColor": "#0B0F0E",
          "dark": {
            "backgroundColor": "#0B0F0E"
          }
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow $(PRODUCT_NAME) to use the microphone to capture spoken expenses.",
          "speechRecognitionPermission": "Allow $(PRODUCT_NAME) to use speech recognition to transcribe spoken expenses.",
          "androidSpeechServicePackages": [
            "com.google.android.googlequicksearchbox"
          ]
        }
      ],
      "expo-asset",
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ],
      "./plugins/withSmsAppIntent",
      "expo-secure-store",
      "@bacons/apple-targets",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "71a16c6f-6abc-4172-b12a-9958a6d05f44"
      }
    },
    "owner": "leo_pepsi_2"
  }
}
